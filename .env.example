# Number of concurrent worker containers (each handles one question at a time)
WORKER_COUNT=4

# Slack app credentials — get these from https://api.slack.com/apps
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token

# ngrok auth token — free at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_token

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Databricks — host is your workspace URL, e.g. https://adb-1234567890.12.azuredatabricks.net
# Warehouse ID is found in SQL Warehouses > your warehouse > Connection details
# Access token: User settings > Developer > Access tokens > Generate new token
DATABRICKS_HOST=https://adb-xxxxxxxxxxxx.xx.azuredatabricks.net
DATABRICKS_WAREHOUSE_ID=xxxxxxxxxxxxxxxx
DATABRICKS_ACCESS_TOKEN=dapixxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
